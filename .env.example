# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# AI proxy (production path): the Cloud Function in front of Gemini.
# When set, the app sends Firebase ID tokens here and never carries an API key.
EXPO_PUBLIC_AI_PROXY_URL=

# Account lifecycle endpoint (guest migration / account deletion, Admin SDK).
# Destructive/cross-account actions REFUSE to run while this is unset.
EXPO_PUBLIC_ACCOUNT_API_URL=

# Google Sign-In: the OAuth *web* client id (google-services.json, client_type 3).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Dev-only fallback when no proxy URL is set: talk to Gemini directly.
# Get a free key at https://aistudio.google.com/apikey — NEVER ship it in builds.
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-flash-latest
