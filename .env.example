# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Gemini — get a free key at https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=
# Model id. Cheapest: gemini-2.5-flash-lite · balanced: gemini-2.5-flash
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# --- Firebase (only needed once the app has accounts / data / storage) ---
# Install: npx expo install firebase
# Then fill these and wire src/firebase.ts (see README).
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_APP_ID=
