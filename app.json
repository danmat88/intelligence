{
  "expo": {
    "name": "Rezolvo",
    "slug": "intelligence",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F7FB",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.rezolvo.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "allowBackup": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-google-signin/google-signin",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics",
      [
        "expo-splash-screen",
        {
          "image": "./assets/android-icon-foreground.png",
          "imageWidth": 192,
          "resizeMode": "contain",
          "backgroundColor": "#F5F7FB"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Rezolvo to use the camera to photograph math problems."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Rezolvo to access your photos to solve problems from images.",
          "cameraPermission": "Allow Rezolvo to use the camera to snap math problems."
        }
      ],
      [
        "react-native-edge-to-edge",
        {
          "android": {
            "enforceNavigationBarContrast": false
          }
        }
      ]
    ],
    "owner": "matdan88-studio",
    "extra": {
      "eas": {
        "projectId": "02602e9d-57be-4486-8138-7e8650c828c0"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/02602e9d-57be-4486-8138-7e8650c828c0"
    }
  }
}
